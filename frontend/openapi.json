  "info": {
    "title": "WC2026 Terminal API",
    "version": "1.0.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/v1/health": {
      "get": {
        "description": "Config fences + ledger freshness.\n\nLedger recency is the best available \"is anything happening\" signal today;\nthe per-source freshness matrix arrives in Phase 6 once ingestion actually\nwrites snapshots.",
        "operationId": "get_health_api_v1_health_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Envelope_HealthData_"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Get Health"
      }
    },
    "/api/v1/ledger": {
      "get": {
        "operationId": "read_ledger_api_v1_ledger_get",
        "parameters": [
          {
            "description": "Return entries with seq > after_seq.",
            "in": "query",
            "name": "after_seq",
            "required": false,
            "schema": {
              "default": -1,
              "description": "Return entries with seq > after_seq.",
              "title": "After Seq",
              "type": "integer"
            }
          },
          {
            "description": "Filter by entry kind.",
            "in": "query",
            "name": "kind",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Filter by entry kind.",
              "title": "Kind"
            }
          },
          {
            "in": "query",
            "name": "limit",
            "required": false,
            "schema": {
              "default": 100,
              "maximum": 1000,
              "minimum": 1,
              "title": "Limit",
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Envelope_LedgerPage_"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Read Ledger"
      }
    },
    "/api/v1/ledger/verify": {
      "get": {
        "operationId": "verify_ledger_api_v1_ledger_verify_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Envelope_LedgerVerification_"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Verify Ledger"
      }
    },
    "/api/v1/matches": {
      "get": {
        "operationId": "get_matches_api_v1_matches_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Envelope_list_MatchPrediction__"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Get Matches"
      }
    },
    "/api/v1/opportunities": {
      "get": {
        "operationId": "get_opportunities_api_v1_opportunities_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Envelope_list_MarketOpportunity__"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Get Opportunities"
      }
    },
    "/api/v1/runs": {
      "get": {
        "operationId": "list_runs_api_v1_runs_get",
        "parameters": [
          {
            "in": "query",
            "name": "limit",
            "required": false,
            "schema": {
              "default": 50,
              "maximum": 500,
              "minimum": 1,
              "title": "Limit",
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Envelope_RunsPage_"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "List Runs"
      }
    },
    "/api/v1/runs/{run_id}": {
      "get": {
        "operationId": "get_run_api_v1_runs__run_id__get",
        "parameters": [
          {
            "in": "path",
            "name": "run_id",
            "required": true,
            "schema": {
              "title": "Run Id",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Envelope_RunOut_"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Get Run"
      }
    }
  }
}
